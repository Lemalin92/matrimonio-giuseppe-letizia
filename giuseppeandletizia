<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Giuseppe & Letizia | 2 Giugno 2027</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
:root{
--blue:#0D4D92;
--yellow:#F9D342;
--gold:#D8B56A;
--cream:#FFFDF7;
--dark:#223;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Montserrat',sans-serif;
background:var(--cream);
color:var(--dark);
line-height:1.7;
overflow-x:hidden;
}

section{
padding:80px 10%;
}

h1,h2,h3{
font-family:'Playfair Display',serif;
}

h2{
font-size:2.8rem;
color:var(--blue);
margin-bottom:30px;
text-align:center;
}

.hero{
height:100vh;
background:
linear-gradient(rgba(13,77,146,.55),rgba(13,77,146,.55)),
url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1600&q=80');
background-size:cover;
background-position:center;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
position:relative;
}

.hero-content{
max-width:900px;
padding:20px;
}

.hero h1{
font-size:5rem;
margin-bottom:20px;
}

.hero p{
font-size:1.4rem;
margin-bottom:20px;
}

.lemon{
font-size:2rem;
}

.countdown{
display:flex;
justify-content:center;
gap:20px;
margin-top:30px;
flex-wrap:wrap;
}

.count-item{
background:rgba(255,255,255,.15);
backdrop-filter:blur(6px);
padding:15px;
border-radius:12px;
min-width:90px;
}

.count-item span{
display:block;
font-size:2rem;
font-weight:bold;
}

.btn{
display:inline-block;
margin:15px;
padding:14px 28px;
background:var(--yellow);
color:#000;
text-decoration:none;
border-radius:30px;
font-weight:600;
transition:.3s;
}

.btn:hover{
transform:translateY(-3px);
}

.story{
background:white;
}

.timeline{
max-width:800px;
margin:auto;
text-align:center;
font-size:1.1rem;
}

.event-card{
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 10px 30px rgba(0,0,0,.08);
max-width:800px;
margin:auto;
text-align:center;
}

.schedule{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-top:30px;
}

.schedule-item{
background:white;
padding:25px;
border-radius:15px;
box-shadow:0 8px 25px rgba(0,0,0,.08);
text-align:center;
}

.rsvp{
background:var(--blue);
color:white;
}

form{
max-width:700px;
margin:auto;
display:flex;
flex-direction:column;
gap:15px;
}

input, textarea, select{
padding:14px;
border:none;
border-radius:10px;
font-size:1rem;
}

button{
padding:14px;
background:var(--yellow);
border:none;
border-radius:10px;
font-weight:bold;
cursor:pointer;
}

.gift-box{
background:white;
padding:30px;
border-radius:20px;
max-width:700px;
margin:auto;
text-align:center;
}

.iban{
font-size:1.3rem;
font-weight:bold;
color:var(--blue);
margin-top:15px;
}

.hotels{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.hotel{
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 8px 25px rgba(0,0,0,.08);
}

.hotel img{
width:100%;
height:220px;
object-fit:cover;
}

.hotel-content{
padding:20px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:15px;
}

.gallery img{
width:100%;
height:280px;
object-fit:cover;
border-radius:15px;
}

.footer{
background:var(--blue);
color:white;
text-align:center;
padding:40px 20px;
}

.wave{
position:absolute;
bottom:0;
left:0;
width:100%;
}

@media(max-width:768px){

.hero h1{
font-size:3rem;
}

h2{
font-size:2rem;
}

section{
padding:60px 6%;
}

}
</style>
</head>
